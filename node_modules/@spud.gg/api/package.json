{
  "name": "@spud.gg/api",
  "version": "0.0.24",
  "description": "spud! the api.",
  "keywords": [
    "api",
    "controller",
    "gamepad",
    "spud",
    "typescript",
    "web audio"
  ],
  "license": "MIT",
  "author": "spud",
  "files": [
    "dist",
    "examples",
    "readme.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "5.8.3"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --format esm",
    "types": "tsc --emitDeclarationOnly"
  }
}